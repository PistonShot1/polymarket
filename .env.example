# Polymarket CLOB credentials — copy to .env and fill in. NEVER commit .env.

# CLOB API host (default is fine)
CLOB_HOST=https://clob.polymarket.com

# Data API host — used for active positions (default is fine)
DATA_API_HOST=https://data-api.polymarket.com

# Polygon chain id (137 mainnet)
CHAIN_ID=137

# Wallet private key used for L1 signing (0x-prefixed, 64 hex chars).
# This is the EOA that owns / controls the Polymarket account.
PRIVATE_KEY=0xyour_private_key_here

# --- Optional: only needed for Polymarket proxy / email (Magic) wallets ---
# Signature type: 0 = EOA, 1 = email/Magic proxy, 2 = browser (Metamask) proxy
SIGNATURE_TYPE=0
# The Polymarket proxy wallet address (your funded address shown in the UI).
# Required when SIGNATURE_TYPE is 1 or 2.
POLYMARKET_PROXY_ADDRESS=

# --- Deposit wallet (POLY_1271 / signature type 3) — for market orders via v2 SDK ---
# Your auto-deployed Polymarket deposit wallet address (the funder holding pUSD/USDC).
# Shown in the polymarket.com console. Funds + approvals must live HERE, not the EOA.
DEPOSIT_WALLET_ADDRESS=

# Token (outcome) id to trade. Get from the Markets API / market object.
TOKEN_ID=

# --- Optional: pre-generated L2 API creds ---
# If left blank the script derives them from PRIVATE_KEY automatically.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
